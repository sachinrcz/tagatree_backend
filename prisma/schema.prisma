generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Cycle {
  id           String   @id @default(cuid())
  name         String
  cycleEndDate DateTime
  capacity     Int
  paidCount    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
